S14_DB_DSN=
S14_REPORT_OUTPUT_DIR=/var/lib/ota-marketing-diagnosis/reports
S14_PUBLIC_BASE_URL=http://YOUR_SERVER:8081/s14-reports
# Feishu app credentials used by the HTTP card callback service.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
S14_FEISHU_CALLBACK_HOST=127.0.0.1
S14_FEISHU_CALLBACK_PORT=8091
S14_FEISHU_CALLBACK_PATH=/s14/feishu/card-callback
# Keep disabled until the callback service is deployed and Feishu callback
# delivery points to its public HTTPS URL.
S14_FEISHU_CARD_CALLBACK_ENABLED=0
